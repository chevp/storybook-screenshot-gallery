# Copy to scripts/.env and fill in. scripts/.env is gitignored.

FTP_HOST=your-host.example.com
FTP_USERNAME=your-user
FTP_PASSWORD=your-password
FTP_PORT=21

# Remote subpath under the FTPS user root.
DEPLOY_PATH=gallery

# Optional: override the Playwright image tag. Must match @playwright/test in package.json.
# PLAYWRIGHT_IMAGE=mcr.microsoft.com/playwright:v1.48.2-jammy