{
  "name": "storybook-screenshot-gallery",
  "version": "0.1.0",
  "private": true,
  "description": "Template for documenting a web app via Playwright screenshots rendered in a static Storybook gallery, deployed through Docker.",
  "type": "module",
  "scripts": {
    "dev": "vite --port 4200 --strictPort",
    "build": "vite build",
    "preview": "vite preview --port 4200 --strictPort",
    "e2e:scenarios": "playwright test e2e/scenarios/",
    "storybook": "storybook dev -p 6006",
    "storybook:build": "mkdir -p e2e/screenshots/scenarios && storybook build -o storybook-static"
  },
  "devDependencies": {
    "@playwright/test": "1.48.2",
    "@storybook/html": "^10.3.5",
    "@storybook/html-vite": "^10.3.5",
    "storybook": "^10.3.5",
    "typescript": "^5.5.0",
    "vite": "^5.4.0"
  }
}